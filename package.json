{
  "name": "foundation-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "archiver:dev": "cargo run --manifest-path rust-archiver/Cargo.toml",
    "clean:dev": "node ./scripts/clean-dev.mjs",
    "contracts:seed": "tsx scripts/seed-contracts.ts",
    "db:bootstrap": "prisma db push --force-reset && prisma generate",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:start": "docker compose -f docker-compose.postgres.yml up -d",
    "db:stop": "docker compose -f docker-compose.postgres.yml down",
    "db:studio": "prisma studio",
    "dev": "node ./scripts/dev.mjs",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "queue:foundation": "tsx scripts/queue-foundation-urls.ts",
    "queue:drain": "tsx scripts/process-queue.ts",
    "queue:scan-contract": "tsx scripts/queue-contract-scan.ts",
    "socket": "tsx scripts/socket-server.ts",
    "start": "next start",
    "tsxe": "node --import tsx ./scripts/tsxe.mjs",
    "typecheck": "tsc --noEmit",
    "worker": "tsx scripts/worker.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.7.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "multiformats": "^13.4.2",
    "next": "^15.2.3",
    "next-themes": "^0.4.4",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.48.1",
    "ws": "^8.20.0",
    "zod": "^3.24.2",
    "zod-form-data": "^3.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
