{
  "name": "foundation-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && tsc --noEmit",
    "archiver:dev": "cargo run --manifest-path rust-archiver/Cargo.toml",
    "clean:dev": "node ./scripts/clean-dev.mjs",
    "contracts:seed": "tsx scripts/seed-contracts.ts",
    "db:bootstrap": "prisma db push --force-reset && prisma generate",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:start": "docker compose -f docker-compose.postgres.yml up -d",
    "db:stop": "docker compose -f docker-compose.postgres.yml down",
    "db:studio": "prisma studio",
    "dev": "node ./scripts/dev.mjs",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "eslint src eslint.config.js next.config.js postcss.config.js prettier.config.js",
    "lint:fix": "eslint src eslint.config.js next.config.js postcss.config.js prettier.config.js --fix",
    "lint:full": "eslint .",
    "preview": "next build && next start",
    "queue:foundation": "tsx scripts/queue-foundation-urls.ts",
    "profiles:apply-schema": "tsx scripts/apply-profile-asset-schema.ts",
    "profiles:backfill-assets": "tsx scripts/backfill-profile-assets.ts",
    "profiles:backfill-status": "tsx scripts/backfill-profile-assets.ts --status",
    "queue:drain": "tsx scripts/process-queue.ts",
    "cid-index:backfill": "tsx scripts/backfill-cid-index.ts",
    "queue:scan-contract": "tsx scripts/queue-contract-scan.ts",
    "migrate:kubo-pins": "tsx scripts/migrate-kubo-pins.ts",
    "socket": "tsx scripts/socket-server.ts",
    "start": "next start",
    "tsxe": "node --import tsx ./scripts/tsxe.mjs",
    "typecheck": "tsc --noEmit",
    "worker": "tsx scripts/worker.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.7.0",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "multiformats": "^13.4.2",
    "next": "^16.2.4",
    "next-themes": "^0.4.4",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.48.1",
    "wagmi": "^2.19.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
