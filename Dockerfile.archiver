FROM rust:1.88-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  libayatana-appindicator3-dev \
  libgtk-3-dev \
  libxdo-dev \
  pkg-config \
  xdg-utils \
  && rm -rf /var/lib/apt/lists/*

COPY rust-archiver ./rust-archiver

RUN cargo build --manifest-path rust-archiver/Cargo.toml --release

ENV ARCHIVE_ARCHIVER_BIND=0.0.0.0:43131

EXPOSE 43131

CMD ["/app/rust-archiver/target/release/foundation-archive-archiver"]
