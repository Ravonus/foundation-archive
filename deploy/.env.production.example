POSTGRES_DB=foundation_archive
POSTGRES_USER=foundation_archive
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://foundation_archive:change-me@postgres:5432/foundation_archive?schema=public

WEB_PORT=3000
ARCHIVE_SOCKET_PORT=43129
NEXT_PUBLIC_SITE_URL=http://192.168.1.190:3000
NEXT_PUBLIC_ARCHIVE_SOCKET_URL=http://192.168.1.190:43129
ARCHIVE_SOCKET_INTERNAL_URL=http://socket:43129

FOUNDATION_BASE_URL=https://foundation.app
FOUNDATION_GRAPHQL_API_URL=https://api.prod.foundation.app/graphql
IPFS_GATEWAY_BASE_URL=https://ipfs.io

ARCHIVE_STORAGE_DIR=/mnt/backups/foundation
ARCHIVE_HOT_STORAGE_DIR=/data/archive-storage-hot
ARCHIVE_ARCHIVER_URL=http://archiver:43131
ARCHIVE_ARCHIVER_BIND=0.0.0.0:43131
ARCHIVE_ARCHIVER_MEMORY_CACHE_ITEMS=512
ARCHIVE_ARCHIVER_INLINE_MEMORY_MAX_BYTES=8388608

AUTO_CRAWLER_ENABLED=true
AUTO_SCAN_BLOCK_WINDOW=50000
AUTO_SCAN_CONTRACTS_PER_TICK=1
SMART_PIN_START_BYTES=1048576
SMART_PIN_CEILING_BYTES=268435456
SMART_PIN_GROWTH_FACTOR=2
SMART_PIN_DEFER_MS=60000

ETHEREUM_RPC_URL=
KUBO_API_URL=
KUBO_API_AUTH_HEADER=
INTERNAL_CRON_SECRET=

NAS_HOST=technomancyit
NAS_SHARE=backups
NAS_ARCHIVE_SUBDIR=foundation
NAS_USERNAME=replace-me
NAS_PASSWORD=replace-me
NAS_SMB_VERS=3.0
